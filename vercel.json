{
  "version": 2,
  "framework": null,
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.7.4"
    }
  ],
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/api/index.php"
    },
    {
      "src": "/images/(.*)",
      "dest": "/api/index.php"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/api/index.php"
    },
    {
      "src": "/resume/(.*)",
      "dest": "/api/index.php"
    },
    {
      "src": "/favicon.ico",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
